# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# No NEXT_PUBLIC_ prefix on purpose: read only server-side (app/api/gemini/route.ts)
# so the key never gets bundled into client JS.
GEMINI_API_KEY=
NEXT_PUBLIC_GOOGLE_TTS_API_KEY=

# Backup LLM — used automatically when Gemini hits a rate limit / quota error.
# No NEXT_PUBLIC_ prefix on purpose: this key is only read server-side in
# app/api/grok/route.ts and must never be bundled into client JS.
GROK_API_KEY=
GROK_MODEL=grok-4-fast